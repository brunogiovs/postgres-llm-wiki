#!/usr/bin/env bash
# Create or refresh the project-local Python virtual environment under
# .wiki-runtime/venv and install requirements.txt into it.
#
# This is the only script that is expected to run with the host
# python3. Every other script must run from the project venv (see
# wiki_tooling.require_project_venv). Nothing here touches the system
# or user site-packages.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME_DIR="$REPO_ROOT/.wiki-runtime"
VENV_DIR="$RUNTIME_DIR/venv"
REQUIREMENTS="$REPO_ROOT/requirements.txt"

mkdir -p "$RUNTIME_DIR"
chmod 700 "$RUNTIME_DIR" 2>/dev/null || true

if [ ! -x "$VENV_DIR/bin/python" ]; then
    echo "Creating project venv at ${VENV_DIR#$REPO_ROOT/}"
    python3 -m venv "$VENV_DIR"
fi

# Upgrade pip inside the venv only; never touches host pip.
"$VENV_DIR/bin/python" -m pip install --quiet --upgrade pip

if [ -s "$REQUIREMENTS" ] && grep -Eq '^[^#[:space:]]' "$REQUIREMENTS"; then
    "$VENV_DIR/bin/python" -m pip install --quiet --require-virtualenv -r "$REQUIREMENTS"
fi

echo "Project venv ready: ${VENV_DIR#$REPO_ROOT/}"
echo "Run scripts via: ${VENV_DIR#$REPO_ROOT/}/bin/python scripts/<name>"
echo "Or activate:     source ${VENV_DIR#$REPO_ROOT/}/bin/activate"
