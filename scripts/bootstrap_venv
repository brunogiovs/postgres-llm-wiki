#!/usr/bin/env bash
# Create or refresh the project-local Python virtual environment under
# .wiki-runtime/venv and install requirements.txt into it.
#
# This script is fully self-contained: it does NOT require any
# system-installed Python or package manager. It downloads a pinned
# `uv` release into .wiki-runtime/bin/, then uses uv to fetch a
# project-local Python interpreter under .wiki-runtime/python/ and
# create the venv. The only host requirements are a POSIX shell, curl,
# and tar — nothing is written outside the project tree.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME_DIR="$REPO_ROOT/.wiki-runtime"
VENV_DIR="$RUNTIME_DIR/venv"
REQUIREMENTS="$REPO_ROOT/requirements.txt"

# Pinned tooling versions. Bump explicitly; do not auto-update.
UV_VERSION="0.5.11"
PYTHON_VERSION="3.12"   # graphifyy requires >=3.10,<3.14

UV_BIN_DIR="$RUNTIME_DIR/bin"
UV="$UV_BIN_DIR/uv"

# Confine all uv state to the project tree — never touch $HOME caches.
export UV_CACHE_DIR="$RUNTIME_DIR/uv-cache"
export UV_PYTHON_INSTALL_DIR="$RUNTIME_DIR/python"
export UV_TOOL_DIR="$RUNTIME_DIR/uv-tools"
export UV_TOOL_BIN_DIR="$UV_BIN_DIR"
unset UV_PROJECT_ENVIRONMENT

mkdir -p "$RUNTIME_DIR" "$UV_BIN_DIR"
chmod 700 "$RUNTIME_DIR" 2>/dev/null || true

detect_uv_target() {
    local os arch
    os="$(uname -s)"
    arch="$(uname -m)"
    case "$os/$arch" in
        Darwin/arm64)  echo "aarch64-apple-darwin" ;;
        Darwin/x86_64) echo "x86_64-apple-darwin" ;;
        Linux/x86_64)  echo "x86_64-unknown-linux-gnu" ;;
        Linux/aarch64) echo "aarch64-unknown-linux-gnu" ;;
        *)
            echo "error: no prebuilt uv binary for $os/$arch" >&2
            return 1
            ;;
    esac
}

if [ ! -x "$UV" ]; then
    target="$(detect_uv_target)"
    url="https://github.com/astral-sh/uv/releases/download/${UV_VERSION}/uv-${target}.tar.gz"
    echo "Fetching uv ${UV_VERSION} (${target}) into ${UV_BIN_DIR#$REPO_ROOT/}/"
    tmp="$(mktemp -d "${TMPDIR:-/tmp}/wiki-uv.XXXXXX")"
    cleanup_tmp() { rm -rf "$tmp"; }
    trap cleanup_tmp EXIT
    curl --fail --silent --show-error --location "$url" -o "$tmp/uv.tar.gz"
    tar -xzf "$tmp/uv.tar.gz" -C "$tmp"
    install -m 0755 "$tmp/uv-${target}/uv"  "$UV"
    install -m 0755 "$tmp/uv-${target}/uvx" "$UV_BIN_DIR/uvx"
    cleanup_tmp
    trap - EXIT
fi

# Fetch the requested Python into .wiki-runtime/python/ if missing.
"$UV" python install "$PYTHON_VERSION"

if [ ! -x "$VENV_DIR/bin/python" ]; then
    echo "Creating project venv at ${VENV_DIR#$REPO_ROOT/} using Python ${PYTHON_VERSION}"
    "$UV" venv --python "$PYTHON_VERSION" "$VENV_DIR"
fi

if [ -s "$REQUIREMENTS" ] && grep -Eq '^[^#[:space:]]' "$REQUIREMENTS"; then
    "$UV" pip install --python "$VENV_DIR/bin/python" -r "$REQUIREMENTS"
fi

echo "Project venv ready: ${VENV_DIR#$REPO_ROOT/}"
echo "Run scripts via: ${VENV_DIR#$REPO_ROOT/}/bin/python scripts/<name>"
echo "Or activate:     source ${VENV_DIR#$REPO_ROOT/}/bin/activate"
