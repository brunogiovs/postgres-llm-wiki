#!/usr/bin/env python3
"""Search or display files from a project-local PostgreSQL source checkout."""

from __future__ import annotations

import argparse
import re
import shutil
import subprocess
import sys
from pathlib import Path

sys.dont_write_bytecode = True

from wiki_tooling import append_tool_log, die, load_versions, safe_source_path, source_checkout


def print_file(path: Path, start: int, limit: int) -> int:
    if not path.exists():
        print(f"error: path does not exist: {path}", file=sys.stderr)
        return 2
    if path.is_dir():
        for child in sorted(path.iterdir()):
            print(child.name + ("/" if child.is_dir() else ""))
        return 0

    end = start + limit - 1 if limit > 0 else None
    with path.open("r", encoding="utf-8", errors="replace") as handle:
        for lineno, line in enumerate(handle, start=1):
            if lineno < start:
                continue
            if end is not None and lineno > end:
                break
            print(f"{lineno:6d}\t{line.rstrip()}")
    return 0


def search_symbol(root: Path, symbol: str, limit: int, regex: bool) -> int:
    if shutil.which("rg"):
        cmd = ["rg", "-n", "--hidden", "--glob", "!.git"]
        if not regex:
            cmd.append("--fixed-strings")
        cmd.extend(["--", symbol, "."])
        proc = subprocess.run(cmd, cwd=root, text=True, capture_output=True)
        if proc.returncode > 1:
            print(proc.stderr.rstrip(), file=sys.stderr)
            return proc.returncode
        lines = proc.stdout.splitlines()
    elif (root / ".git").exists() and shutil.which("git"):
        cmd = ["git", "-C", str(root), "grep", "-n"]
        # `git grep` defaults to POSIX BRE; use ERE under --regex so that the
        # alternation/repetition syntax matches what ripgrep accepts as a baseline.
        cmd.append("-E" if regex else "-F")
        cmd.extend(["--", symbol])
        proc = subprocess.run(cmd, text=True, capture_output=True)
        if proc.returncode > 1:
            print(proc.stderr.rstrip(), file=sys.stderr)
            return proc.returncode
        lines = proc.stdout.splitlines()
    else:
        lines = []
        if regex:
            try:
                pattern = re.compile(symbol)
            except re.error as exc:
                print(f"error: invalid regex {symbol!r}: {exc}", file=sys.stderr)
                return 2
        else:
            pattern = None
        for path in root.rglob("*"):
            if ".git" in path.parts or not path.is_file():
                continue
            try:
                for lineno, line in enumerate(path.read_text(encoding="utf-8", errors="replace").splitlines(), start=1):
                    matched = bool(pattern.search(line)) if pattern else symbol in line
                    if matched:
                        lines.append(f"{path}:{lineno}:{line}")
            except OSError:
                continue

    if limit > 0:
        lines = lines[:limit]
    if lines:
        print("\n".join(lines))
        return 0
    print(f"no matches for {symbol!r}", file=sys.stderr)
    return 1


def show_log(root: Path, rel_path: str, limit: int) -> int:
    if not (root / ".git").exists():
        print(f"error: checkout has no .git directory: {root}", file=sys.stderr)
        return 2
    cmd = ["git", "-C", str(root), "log", "--oneline", f"--max-count={limit}", "--", rel_path]
    proc = subprocess.run(cmd, text=True, capture_output=True)
    if proc.stdout:
        print(proc.stdout.rstrip())
    if proc.stderr:
        print(proc.stderr.rstrip(), file=sys.stderr)
    return proc.returncode


def main(argv: list[str] | None = None) -> int:
    versions = load_versions()
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--version", required=True, help="PostgreSQL major version")
    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument("--symbol", help="symbol or text to search for")
    mode.add_argument("--path", help="source path to display, relative to the checkout")
    mode.add_argument("--log", help="source path whose git history should be shown")
    parser.add_argument("--regex", action="store_true", help="treat --symbol as a regular expression")
    parser.add_argument("--start", type=int, default=1, help="first line to print for --path")
    parser.add_argument("--limit", type=int, default=100, help="maximum matches, log entries, or file lines")
    args = parser.parse_args(argv)

    append_tool_log("source_lookup", sys.argv[1:])
    if args.version not in versions:
        die(f"unsupported PostgreSQL version: {args.version}")
    root = source_checkout(args.version)

    if args.path:
        return print_file(safe_source_path(args.version, args.path), max(args.start, 1), args.limit)
    if args.log:
        safe_source_path(args.version, args.log)
        return show_log(root, args.log, args.limit)
    return search_symbol(root, args.symbol, args.limit, args.regex)


if __name__ == "__main__":
    raise SystemExit(main())
