#!/usr/bin/env python3
"""Delete and reclone a PostgreSQL source checkout, pinned to the latest upstream release tag.

Queries the official PostgreSQL mirror for the newest release tag matching the
major version (stable releases preferred over RC, RC over beta), wipes the
existing checkout, clones fresh, pins to that tag, then updates
wiki/versions.md and appends to wiki/log.md.

Usage:
  scripts/source_rebuild --version 18
  scripts/source_rebuild --version 18 --dry-run
"""

from __future__ import annotations

import argparse
import re
import shutil
import subprocess
import sys
from datetime import date
from pathlib import Path

sys.dont_write_bytecode = True

from wiki_tooling import REPO_ROOT, WIKI_ROOT, append_tool_log, die, load_versions

MIRROR = "https://github.com/postgres/postgres.git"
RAW_ROOT = REPO_ROOT / "raw"

# Tag tiers: stable releases outrank RCs which outrank betas.
_STABLE_RE = re.compile(r"^REL_(\d+)_(\d+)$")
_RC_RE = re.compile(r"^REL_(\d+)_RC(\d+)$", re.IGNORECASE)
_BETA_RE = re.compile(r"^REL_(\d+)_BETA(\d+)$", re.IGNORECASE)


def _tag_sort_key(tag: str, version: str) -> tuple[int, int] | None:
    """Return (tier, minor) for tags belonging to *version*, or None to skip."""
    m = _STABLE_RE.match(tag)
    if m and m.group(1) == version:
        return (3, int(m.group(2)))
    m = _RC_RE.match(tag)
    if m and m.group(1) == version:
        return (2, int(m.group(2)))
    m = _BETA_RE.match(tag)
    if m and m.group(1) == version:
        return (1, int(m.group(2)))
    return None


def latest_release_tag(version: str) -> tuple[str, str]:
    """Return (tag_name, commit_sha) for the newest release tag on the remote."""
    print(f"querying remote tags for PostgreSQL {version} …")
    proc = subprocess.run(
        ["git", "ls-remote", "--tags", MIRROR, f"refs/tags/REL_{version}_*"],
        text=True,
        capture_output=True,
        check=True,
    )
    candidates: list[tuple[tuple[int, int], str, str]] = []
    for line in proc.stdout.splitlines():
        line = line.strip()
        if not line or "^{}" in line:
            continue
        sha, ref = line.split("\t", 1)
        tag = ref.removeprefix("refs/tags/")
        key = _tag_sort_key(tag, version)
        if key is not None:
            candidates.append((key, tag, sha))

    if not candidates:
        die(
            f"no release tags found for PostgreSQL {version} on the mirror; "
            "check that the version number is correct"
        )

    candidates.sort(key=lambda c: c[0], reverse=True)
    _, tag, sha = candidates[0]

    # ls-remote gives us the tag object SHA; resolve to the commit SHA.
    resolve = subprocess.run(
        ["git", "ls-remote", MIRROR, f"refs/tags/{tag}^{{}}"],
        text=True,
        capture_output=True,
    )
    for line in resolve.stdout.splitlines():
        if "^{}" in line:
            sha = line.split("\t", 1)[0].strip()
            break

    return tag, sha


def do_clone(checkout: Path, tag: str, commit: str) -> None:
    RAW_ROOT.mkdir(parents=True, exist_ok=True)
    print(f"cloning postgres at tag {tag} into {checkout.relative_to(REPO_ROOT)} …")
    subprocess.run(
        ["git", "clone", "--filter=blob:none", "--branch", tag, MIRROR, str(checkout)],
        check=True,
        text=True,
    )
    subprocess.run(
        ["git", "-C", str(checkout), "checkout", "--detach", commit],
        check=True,
        text=True,
    )
    head = subprocess.run(
        ["git", "-C", str(checkout), "rev-parse", "HEAD"],
        text=True,
        capture_output=True,
        check=True,
    ).stdout.strip()
    print(f"checkout ready: {head}")


def update_versions_md(version: str, tag: str, commit: str, dry_run: bool) -> bool:
    """Update the pinned commit in wiki/versions.md. Return True if changed."""
    path = WIKI_ROOT / "versions.md"
    original = path.read_text(encoding="utf-8")
    lines = original.splitlines(keepends=True)
    changed = False

    updated: list[str] = []
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("|"):
            cells = [c.strip() for c in stripped.strip("|").split("|")]
            if cells and cells[0] == version:
                # Replace branch (col 3) and commit (col 4) in the table row.
                # Reconstruct by splitting on | and editing the cell values.
                parts = line.rstrip("\n").split("|")
                # parts[0] is empty (leading |), parts[1..N] are cells, parts[-1] trailing
                if len(parts) >= 6:
                    old_commit = parts[5].strip().strip("`")
                    if old_commit != commit:
                        parts[4] = f" `{tag}` "
                        parts[5] = f" `{commit}` "
                        line = "|".join(parts) + "\n"
                        changed = True
        # Update the "## Current Primary" summary block.
        if line.startswith("- Branch:") and f"`{version}" not in line:
            pass  # not this version's block; leave alone
        if line.strip().startswith("- Pinned commit:") and changed:
            line = f"- Pinned commit: `{commit}`\n"
        if line.strip().startswith("- Branch:") and changed:
            line = f"- Branch: `{tag}`\n"
        updated.append(line)

    new_text = "".join(updated)
    if new_text == original:
        return False
    if not dry_run:
        path.write_text(new_text, encoding="utf-8")
    return changed


def append_log(version: str, tag: str, commit: str, old_commit: str, dry_run: bool) -> None:
    log_path = WIKI_ROOT / "log.md"
    today = date.today().isoformat()
    entry = (
        f"\n## [{today}] source-rebuild v{version} | pinned to {tag}\n\n"
        f"- Deleted and recloned `raw/postgres-{version}/` from the official mirror.\n"
        f"- Resolved tag `{tag}` to commit `{commit}`.\n"
        f"- Previous pin: `{old_commit}`.\n"
        f"- Updated `wiki/versions.md` branch and pinned commit.\n"
    )
    if dry_run:
        print("--- wiki/log.md entry (dry-run, not written) ---")
        print(entry)
        return
    with log_path.open("a", encoding="utf-8") as f:
        f.write(entry)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--version", required=True, help="PostgreSQL major version to rebuild (e.g. 18)")
    parser.add_argument("--dry-run", action="store_true", help="show what would happen without deleting or writing")
    args = parser.parse_args(argv)

    append_tool_log("source_rebuild", sys.argv[1:])

    version = args.version
    versions = load_versions()
    info = versions.get(version)
    old_commit = info.get("commit", "") if info else ""

    tag, commit = latest_release_tag(version)
    print(f"latest release tag: {tag}  commit: {commit[:12]}")

    if commit == old_commit:
        print(f"already pinned to {commit[:12]} — nothing to do")
        return 0

    checkout = RAW_ROOT / f"postgres-{version}"

    if args.dry_run:
        print(f"dry-run: would delete {checkout.relative_to(REPO_ROOT)} and reclone at {tag}")
        print(f"dry-run: would update wiki/versions.md pin from {old_commit[:12]} to {commit[:12]}")
        append_log(version, tag, commit, old_commit, dry_run=True)
        return 0

    if checkout.exists():
        print(f"removing {checkout.relative_to(REPO_ROOT)} …")
        shutil.rmtree(checkout)

    do_clone(checkout, tag, commit)

    changed = update_versions_md(version, tag, commit, dry_run=False)
    if changed:
        print(f"wiki/versions.md updated: pin {old_commit[:12]} → {commit[:12]}")
    else:
        print("wiki/versions.md: no change needed")

    append_log(version, tag, commit, old_commit, dry_run=False)
    print("wiki/log.md updated")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
