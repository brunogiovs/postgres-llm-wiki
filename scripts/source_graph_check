#!/usr/bin/env python3
"""Sanity-check generated Graphify source graphs from raw source pins."""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path

sys.dont_write_bytecode = True

from wiki_tooling import (
    REPO_ROOT,
    RUNTIME_ROOT,
    append_tool_log,
    die,
    find_graphify,
    load_versions,
    render_repo_path,
    source_checkout,
)


REFERENCE_RE = re.compile(
    r"(?P<path>(?:raw|\.wiki-runtime/graph)/postgres-(?P<version>\d+)"
    r"(?:/[^\s`'\"<>|,:\])}]*)?)"
)


@dataclass(frozen=True)
class Issue:
    level: str
    check: str
    message: str


class Reporter:
    def __init__(self) -> None:
        self.issues: list[Issue] = []

    def add(self, level: str, check: str, message: str) -> None:
        self.issues.append(Issue(level, check, message))

    def error(self, check: str, message: str) -> None:
        self.add("ERROR", check, message)

    def warn(self, check: str, message: str) -> None:
        self.add("WARN", check, message)

    def count(self, level: str) -> int:
        return sum(1 for issue in self.issues if issue.level == level)


def path_from_context(text: str) -> Path:
    path = Path(text)
    if path.is_absolute():
        return path.resolve()
    return (REPO_ROOT / path).resolve()


def clean_reference(path_text: str) -> str:
    path_text = re.sub(r"(?::\d+){1,2}$", "", path_text)
    while path_text.endswith((".", ";", ":", ")")):
        path_text = path_text[:-1]
    return path_text


def scan_references(
    version: str,
    reporter: Reporter,
    artifact: Path,
    text: str,
    *,
    missing_level: str = "error",
) -> int:
    count = 0
    normalized = text.replace(str(REPO_ROOT) + "/", "").replace("\\", "/")
    for match in REFERENCE_RE.finditer(normalized):
        count += 1
        rel_text = clean_reference(match.group("path"))
        ref_version = match.group("version")
        if ref_version != version:
            reporter.error(
                "reference-scan",
                f"{render_repo_path(artifact)} references postgres-{ref_version}, expected postgres-{version}: {rel_text}",
            )
            continue
        path = path_from_context(rel_text)
        if not path.exists():
            message = f"{render_repo_path(artifact)} references missing project path: {rel_text}"
            if missing_level == "warn":
                reporter.warn("reference-scan", message)
            elif missing_level != "ignore":
                reporter.error("reference-scan", message)
    return count


def parse_manifest_values(text: str) -> dict[str, str]:
    values: dict[str, str] = {}
    for line in text.splitlines():
        if not line.startswith("- ") or ":" not in line:
            continue
        key, value = line[2:].split(":", 1)
        value = value.strip()
        if len(value) >= 2 and value[0] == "`" and value[-1] == "`":
            value = value[1:-1]
        values[key.strip()] = value
    return values


def source_head(version: str) -> str:
    source = source_checkout(version)
    proc = subprocess.run(
        ["git", "-C", str(source), "rev-parse", "HEAD"],
        cwd=REPO_ROOT,
        text=True,
        capture_output=True,
    )
    if proc.returncode == 0:
        return proc.stdout.strip()
    return "unknown"


def check_version(version: str, info: dict[str, str], args: argparse.Namespace) -> tuple[int, int]:
    reporter = Reporter()
    graph_dir = RUNTIME_ROOT / "graph" / f"postgres-{version}"
    manifest = graph_dir / "manifest.md"
    graph_json = graph_dir / "graph.json"
    report = graph_dir / "GRAPH_REPORT.md"

    if not manifest.is_file():
        reporter.error("manifest", f"missing Graphify manifest: {render_repo_path(manifest)}")
    else:
        text = manifest.read_text(encoding="utf-8", errors="replace")
        values = parse_manifest_values(text)
        expected = info.get("commit", "")
        if values.get("Pinned commit") and values.get("Pinned commit") != expected:
            reporter.error("manifest", f"manifest pinned commit {values.get('Pinned commit')} does not match wiki/versions.md {expected}")
        head = source_head(version)
        if head != "unknown" and values.get("Source checkout HEAD") and values.get("Source checkout HEAD") != head:
            reporter.error("manifest", f"manifest source HEAD {values.get('Source checkout HEAD')} does not match checkout HEAD {head}")
        scan_references(version, reporter, manifest, text, missing_level="ignore")

    if not graph_json.is_file():
        reporter.error("graph.json", f"missing Graphify graph: {render_repo_path(graph_json)}")
    else:
        text = graph_json.read_text(encoding="utf-8", errors="replace")
        try:
            json.loads(text)
        except json.JSONDecodeError as exc:
            reporter.error("graph.json", f"could not parse JSON: {exc}")
        scan_references(version, reporter, graph_json, text)

    if not report.is_file():
        reporter.warn("GRAPH_REPORT.md", f"missing Graphify report: {render_repo_path(report)}")
    else:
        scan_references(version, reporter, report, report.read_text(encoding="utf-8", errors="replace"))

    if args.probe_node:
        graphify_bin = find_graphify()
        if graphify_bin is None:
            reporter.warn("query-probe", "graphify is not installed; skipped explain probe")
        elif graph_json.is_file():
            proc = subprocess.run(
                [graphify_bin, "explain", args.probe_node, "--graph", str(graph_json)],
                text=True,
                capture_output=True,
            )
            if proc.returncode != 0:
                reporter.error("query-probe", f"graphify explain {args.probe_node!r} failed: {proc.stderr.strip()}")

    for issue in reporter.issues:
        print(f"{issue.level} {issue.check}: {issue.message}")
    errors = reporter.count("ERROR")
    warnings = reporter.count("WARN")
    print(f"v{version}: source_graph_check: errors={errors} warnings={warnings}")
    return errors, warnings


def selected_versions(args: argparse.Namespace, versions: dict[str, dict[str, str]]) -> list[str]:
    if args.all:
        return sorted(versions, key=int, reverse=True)
    if args.version not in versions:
        die(f"unsupported PostgreSQL version: {args.version}")
    return [args.version]


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    scope = parser.add_mutually_exclusive_group(required=True)
    scope.add_argument("--version", help="PostgreSQL major version to check")
    scope.add_argument("--all", action="store_true", help="check every supported version")
    parser.add_argument("--probe-node", help="optional node to probe with graphify explain")
    parser.add_argument("--strict", action="store_true", help="return failure for warnings too")
    args = parser.parse_args(argv)

    append_tool_log("source_graph_check", sys.argv[1:])
    versions = load_versions()
    total_errors = 0
    total_warnings = 0
    for version in selected_versions(args, versions):
        errors, warnings = check_version(version, versions[version], args)
        total_errors += errors
        total_warnings += warnings
    if total_errors or (args.strict and total_warnings):
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
