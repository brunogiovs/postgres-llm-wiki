#!/usr/bin/env python3
"""Start, stop, and inspect the local llama.cpp server for this wiki."""

from __future__ import annotations

import argparse
import json
import os
import shlex
import signal
import subprocess
import sys
import time
from pathlib import Path

sys.dont_write_bytecode = True

from wiki_tooling import REPO_ROOT, RUNTIME_ROOT, append_tool_log, die, ensure_runtime_dirs


LLAMA_ROOT = Path(os.environ.get("LLAMA_CPP_ROOT", "/data/ollamacpp/llama.cpp"))
LLAMA_BIN = Path(os.environ.get("LLAMA_SERVER_BIN", str(LLAMA_ROOT / "build" / "bin" / "llama-server")))
DEFAULT_MODEL = str(
    RUNTIME_ROOT
    / "models"
    / "qwen3.5-9b-gguf"
    / "Qwen_Qwen3.5-9B-Q6_K.gguf"
)

SERVER_ROOT = RUNTIME_ROOT / "llama"
PID_FILE = SERVER_ROOT / "llama-server.pid"
COMMAND_FILE = SERVER_ROOT / "llama-server.command"
STDOUT_LOG = RUNTIME_ROOT / "logs" / "llama-server.stdout.log"
STDERR_LOG = RUNTIME_ROOT / "logs" / "llama-server.stderr.log"
EVENT_LOG = RUNTIME_ROOT / "logs" / "llama-server.events.log"


def ensure_dirs() -> None:
    ensure_runtime_dirs()
    SERVER_ROOT.mkdir(parents=True, exist_ok=True)
    (RUNTIME_ROOT / "logs").mkdir(parents=True, exist_ok=True)


def log_event(message: str) -> None:
    ensure_dirs()
    timestamp = time.strftime("%Y-%m-%dT%H:%M:%S")
    with EVENT_LOG.open("a", encoding="utf-8") as handle:
        handle.write(f"{timestamp} {message}\n")


def proc_starttime(pid: int) -> int | None:
    try:
        stat_text = Path(f"/proc/{pid}/stat").read_text(encoding="utf-8")
    except (FileNotFoundError, ProcessLookupError, PermissionError):
        return None
    rparen = stat_text.rfind(")")
    if rparen < 0:
        return None
    fields = stat_text[rparen + 1:].split()
    if len(fields) < 20:
        return None
    try:
        return int(fields[19])
    except ValueError:
        return None


def read_pid_record() -> tuple[int, int] | None:
    try:
        data = json.loads(PID_FILE.read_text(encoding="utf-8"))
        return int(data["pid"]), int(data["starttime"])
    except (FileNotFoundError, json.JSONDecodeError, KeyError, TypeError, ValueError):
        return None


def write_pid_record(pid: int, starttime: int) -> None:
    PID_FILE.write_text(json.dumps({"pid": pid, "starttime": starttime}) + "\n", encoding="utf-8")


def is_running(record: tuple[int, int] | None) -> bool:
    if not record:
        return False
    pid, recorded_starttime = record
    return pid > 0 and proc_starttime(pid) == recorded_starttime


def endpoint_url() -> str:
    host = os.environ.get("LLAMA_HOST", "127.0.0.1")
    port = os.environ.get("LLAMA_PORT", "8080")
    return f"http://{host}:{port}/v1"


def build_command() -> list[str]:
    model = Path(os.environ.get("LLAMA_MODEL", DEFAULT_MODEL))
    if not LLAMA_BIN.exists():
        die(f"llama-server binary not found: {LLAMA_BIN}")
    if not model.exists():
        die(f"GGUF model not found: {model}; set LLAMA_MODEL to a model file")

    command = [
        str(LLAMA_BIN),
        "--model", str(model),
        "--alias", os.environ.get("LLAMA_ALIAS", "pgwiki-local"),
        "--host", os.environ.get("LLAMA_HOST", "127.0.0.1"),
        "--port", os.environ.get("LLAMA_PORT", "8080"),
        "--ctx-size", os.environ.get("LLAMA_CTX_SIZE", "131072"),
        "--n-gpu-layers", os.environ.get("LLAMA_GPU_LAYERS", "auto"),
        "--cache-type-k", os.environ.get("LLAMA_CACHE_TYPE_K", "q4_0"),
        "--cache-type-v", os.environ.get("LLAMA_CACHE_TYPE_V", "q4_0"),
        "--flash-attn", os.environ.get("LLAMA_FLASH_ATTN", "auto"),
        "--reasoning", os.environ.get("LLAMA_REASONING", "off"),
        "--chat-template-kwargs", os.environ.get("LLAMA_CHAT_TEMPLATE_KWARGS", '{"enable_thinking":false}'),
    ]
    extra = os.environ.get("LLAMA_EXTRA_ARGS", "").strip()
    if extra:
        command.extend(shlex.split(extra))
    return command


def render_command(command: list[str]) -> str:
    return " ".join(shlex.quote(part) for part in command)


def start(_args: argparse.Namespace) -> int:
    ensure_dirs()
    record = read_pid_record()
    if record and is_running(record):
        print(f"llama.cpp server already running with pid {record[0]}")
        print(f"endpoint: {endpoint_url()}")
        return 0
    if PID_FILE.exists():
        PID_FILE.unlink()

    command = build_command()
    append_tool_log("llama_server", ["start", render_command(command)])
    with STDOUT_LOG.open("a", encoding="utf-8") as stdout, STDERR_LOG.open("a", encoding="utf-8") as stderr:
        process = subprocess.Popen(
            command,
            cwd=REPO_ROOT,
            stdin=subprocess.DEVNULL,
            stdout=stdout,
            stderr=stderr,
            start_new_session=True,
        )

    starttime = proc_starttime(process.pid)
    if starttime is None:
        die(f"started llama-server pid {process.pid}, but could not read /proc start time")
    write_pid_record(process.pid, starttime)
    COMMAND_FILE.write_text(render_command(command) + "\n", encoding="utf-8")
    log_event(f"started pid={process.pid} endpoint={endpoint_url()} command={render_command(command)}")
    print(f"started llama.cpp server with pid {process.pid}")
    print(f"endpoint: {endpoint_url()}")
    return 0


def status(_args: argparse.Namespace) -> int:
    ensure_dirs()
    record = read_pid_record()
    if record and is_running(record):
        print(f"llama.cpp server running with pid {record[0]}")
        print(f"endpoint: {endpoint_url()}")
        try:
            print(f"command: {COMMAND_FILE.read_text(encoding='utf-8').strip()}")
        except FileNotFoundError:
            pass
        return 0
    print("llama.cpp server stopped")
    return 1


def stop(args: argparse.Namespace) -> int:
    ensure_dirs()
    record = read_pid_record()
    if not record or not is_running(record):
        if PID_FILE.exists():
            PID_FILE.unlink()
        print("llama.cpp server already stopped")
        return 0

    pid, _ = record
    os.kill(pid, signal.SIGTERM)
    deadline = time.time() + args.timeout
    while time.time() < deadline:
        if not is_running(record):
            PID_FILE.unlink(missing_ok=True)
            log_event(f"stopped pid={pid}")
            print(f"stopped llama.cpp server pid {pid}")
            return 0
        time.sleep(0.2)

    if args.force:
        os.kill(pid, signal.SIGKILL)
        PID_FILE.unlink(missing_ok=True)
        log_event(f"force-stopped pid={pid}")
        print(f"force-stopped llama.cpp server pid {pid}")
        return 0

    print(f"llama.cpp server pid {pid} did not stop within {args.timeout:.1f}s; retry with --force", file=sys.stderr)
    return 1


def logs(args: argparse.Namespace) -> int:
    ensure_dirs()
    for label, path in (("events", EVENT_LOG), ("stdout", STDOUT_LOG), ("stderr", STDERR_LOG)):
        print(f"== {label}: {path.relative_to(REPO_ROOT)} ==")
        if not path.exists():
            continue
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
        for line in lines[-args.lines:]:
            print(line)
    return 0


def restart(args: argparse.Namespace) -> int:
    stop(args)
    return start(args)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="command", required=True)

    start_parser = subparsers.add_parser("start")
    start_parser.set_defaults(func=start)

    status_parser = subparsers.add_parser("status")
    status_parser.set_defaults(func=status)

    stop_parser = subparsers.add_parser("stop")
    stop_parser.add_argument("--timeout", type=float, default=10.0)
    stop_parser.add_argument("--force", action="store_true")
    stop_parser.set_defaults(func=stop)

    restart_parser = subparsers.add_parser("restart")
    restart_parser.add_argument("--timeout", type=float, default=10.0)
    restart_parser.add_argument("--force", action="store_true")
    restart_parser.set_defaults(func=restart)

    logs_parser = subparsers.add_parser("logs")
    logs_parser.add_argument("--lines", type=int, default=80)
    logs_parser.set_defaults(func=logs)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
