#!/usr/bin/env python3
"""Query version-pinned PostgreSQL raw source and Graphify graphs.

Raw subcommands read only raw/postgres-NN/. Graph subcommands query the
matching .wiki-runtime/graph/postgres-NN/graph.json, generating it first
when it is absent.

Examples:
  scripts/source_graph_query --version 18 symbol ExecutorRun
  scripts/source_graph_query --version 18 symbol '\bExecutorRun\b' --regex --limit 20
  scripts/source_graph_query --version 18 file src/backend/executor/execMain.c --start 1 --limit 80
  scripts/source_graph_query --version 18 log src/backend/executor/execMain.c --limit 20
  scripts/source_graph_query --version 18 includes src/backend/executor/execMain.c
  scripts/source_graph_query --version 18 included-by executor/executor.h --limit 50
  scripts/source_graph_query --version 18 query "show the executor flow" --dfs
  scripts/source_graph_query --version 18 path ExecutorRun ExecutePlan
  scripts/source_graph_query --version 18 explain PostgresMain
"""

from __future__ import annotations

import argparse
import json
import re
import shutil
import subprocess
import sys
from pathlib import Path

sys.dont_write_bytecode = True

from wiki_tooling import (
    REPO_ROOT,
    RUNTIME_ROOT,
    append_tool_log,
    die,
    load_versions,
    read_include_directives,
    render_repo_path,
    safe_source_path,
    source_checkout,
)


def ensure_graph(version: str) -> Path:
    graph = RUNTIME_ROOT / "graph" / f"postgres-{version}" / "graph.json"
    if graph.is_file():
        return graph

    script = REPO_ROOT / "scripts" / "source_graph"
    if not script.is_file():
        die(f"missing graph generator script: {render_repo_path(script)}")

    proc = subprocess.run(
        [sys.executable, str(script), "--version", version, "--refresh"],
        cwd=REPO_ROOT,
        text=True,
        capture_output=True,
    )
    if proc.returncode != 0 or not graph.is_file():
        if proc.stdout:
            print(proc.stdout.rstrip(), file=sys.stderr)
        if proc.stderr:
            print(proc.stderr.rstrip(), file=sys.stderr)
        die(f"could not generate Graphify graph: {render_repo_path(graph)}")
    return graph


def run_graphify(argv: list[str]) -> int:
    if shutil.which("graphify") is None:
        die("graphify is not installed; install package `graphifyy` to provide the `graphify` CLI")
    proc = subprocess.run(argv, text=True, capture_output=True)
    if proc.stdout:
        print(proc.stdout.rstrip())
    if proc.stderr:
        print(proc.stderr.rstrip(), file=sys.stderr)
    return proc.returncode


def print_file(path: Path, start: int, limit: int) -> int:
    if not path.exists():
        print(f"error: path does not exist: {render_repo_path(path)}", file=sys.stderr)
        return 2
    if path.is_dir():
        for child in sorted(path.iterdir()):
            print(child.name + ("/" if child.is_dir() else ""))
        return 0

    end = start + limit - 1 if limit > 0 else None
    with path.open("r", encoding="utf-8", errors="replace") as handle:
        for lineno, line in enumerate(handle, start=1):
            if lineno < start:
                continue
            if end is not None and lineno > end:
                break
            print(f"{lineno:6d}\t{line.rstrip()}")
    return 0


def search_symbol(root: Path, symbol: str, limit: int, regex: bool) -> int:
    if (root / ".git").exists() and shutil.which("git"):
        cmd = ["git", "-C", str(root), "grep", "-n"]
        cmd.append("-E" if regex else "-F")
        cmd.extend(["--", symbol])
        proc = subprocess.run(cmd, text=True, capture_output=True)
        if proc.returncode > 1:
            print(proc.stderr.rstrip(), file=sys.stderr)
            return proc.returncode
        lines = proc.stdout.splitlines()
    elif shutil.which("rg"):
        cmd = ["rg", "-n", "--hidden", "--glob", "!.git"]
        if not regex:
            cmd.append("--fixed-strings")
        cmd.extend(["--", symbol, "."])
        proc = subprocess.run(cmd, cwd=root, text=True, capture_output=True)
        if proc.returncode > 1:
            print(proc.stderr.rstrip(), file=sys.stderr)
            return proc.returncode
        lines = proc.stdout.splitlines()
    else:
        lines = []
        pattern = None
        if regex:
            try:
                pattern = re.compile(symbol)
            except re.error as exc:
                print(f"error: invalid regex {symbol!r}: {exc}", file=sys.stderr)
                return 2
        for path in root.rglob("*"):
            if ".git" in path.parts or not path.is_file():
                continue
            try:
                text = path.read_text(encoding="utf-8", errors="replace")
            except OSError:
                continue
            for lineno, line in enumerate(text.splitlines(), start=1):
                matched = bool(pattern.search(line)) if pattern else symbol in line
                if matched:
                    rel = path.relative_to(root).as_posix()
                    lines.append(f"{rel}:{lineno}:{line}")

    if limit > 0:
        lines = lines[:limit]
    if lines:
        print("\n".join(lines))
        return 0
    print(f"no matches for {symbol!r}", file=sys.stderr)
    return 1


def show_log(root: Path, rel_path: str, limit: int) -> int:
    if not (root / ".git").exists():
        print(f"error: checkout has no .git directory: {render_repo_path(root)}", file=sys.stderr)
        return 2
    cmd = ["git", "-C", str(root), "log", "--oneline", f"--max-count={limit}", "--", rel_path]
    proc = subprocess.run(cmd, text=True, capture_output=True)
    if proc.stdout:
        print(proc.stdout.rstrip())
    if proc.stderr:
        print(proc.stderr.rstrip(), file=sys.stderr)
    return proc.returncode


def raw_files(root: Path) -> list[Path]:
    if (root / ".git").exists() and shutil.which("git"):
        proc = subprocess.run(
            ["git", "-C", str(root), "ls-files", "*.c", "*.h"],
            text=True,
            capture_output=True,
        )
        if proc.returncode == 0:
            files = [root / line.strip() for line in proc.stdout.splitlines() if line.strip()]
            if files:
                return sorted(files)
    files: list[Path] = []
    for suffix in ("*.c", "*.h"):
        files.extend(path for path in root.rglob(suffix) if path.is_file() and ".git" not in path.parts)
    return sorted(files)


def include_search_roots(root: Path, source: Path | None = None) -> list[Path]:
    roots: list[Path] = []
    if source is not None:
        roots.append(source.parent)
    roots.extend([root / "src/include", root])
    seen: set[Path] = set()
    result: list[Path] = []
    for path in roots:
        resolved = path.resolve()
        if resolved in seen:
            continue
        seen.add(resolved)
        result.append(resolved)
    return result


def resolve_include(root: Path, include: str, *, source: Path | None = None) -> Path | None:
    for directory in include_search_roots(root, source):
        candidate = (directory / include).resolve()
        try:
            candidate.relative_to(root.resolve())
        except ValueError:
            continue
        if candidate.is_file():
            return candidate
    return None


def render_include_rows(rows: list[dict[str, object]], *, as_json: bool, root_key: str) -> int:
    if as_json:
        print(json.dumps({root_key: rows}, indent=2, sort_keys=True))
        return 0
    if not rows:
        print("no include rows")
        return 0
    for row in rows:
        if root_key == "includes":
            resolved = row.get("resolved") or "unresolved"
            print(f"{row['include']} -> {resolved}")
        else:
            print(str(row["source"]))
    return 0


def show_includes(version: str, rel_path: str, *, as_json: bool) -> int:
    root = source_checkout(version).resolve()
    source = safe_source_path(version, rel_path).resolve()
    rows: list[dict[str, object]] = []
    for include in read_include_directives(source):
        resolved = resolve_include(root, include, source=source)
        rows.append(
            {
                "include": include,
                "resolved": render_repo_path(resolved) if resolved else None,
                "source": render_repo_path(source),
            }
        )
    return render_include_rows(rows, as_json=as_json, root_key="includes")


def show_included_by(version: str, target: str, *, limit: int, as_json: bool) -> int:
    root = source_checkout(version).resolve()
    target_path = safe_source_path(version, target).resolve() if (root / target).exists() else resolve_include(root, target)
    if target_path is None:
        die(f"could not resolve include target {target!r} inside raw/postgres-{version}/")

    rows: list[dict[str, object]] = []
    for source in raw_files(root):
        count = 0
        for include in read_include_directives(source):
            resolved = resolve_include(root, include, source=source)
            if resolved is not None and resolved.resolve() == target_path:
                count += 1
        if count:
            rows.append({"source": render_repo_path(source), "include_directives": count})

    rows.sort(key=lambda row: (-int(row["include_directives"]), str(row["source"])))
    if limit > 0:
        rows = rows[:limit]
    return render_include_rows(rows, as_json=as_json, root_key="sources")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--version", required=True, help="PostgreSQL major version")
    subparsers = parser.add_subparsers(dest="command", required=True)

    symbol = subparsers.add_parser("symbol", help="search raw source for a symbol or text")
    symbol.add_argument("symbol", help="symbol or text to search for")
    symbol.add_argument("--regex", action="store_true", help="treat symbol as a regular expression")
    symbol.add_argument("--limit", type=int, default=100, help="maximum matches to print")

    file_parser = subparsers.add_parser("file", help="print a raw source file slice or directory listing")
    file_parser.add_argument("path", help="path relative to raw/postgres-NN/")
    file_parser.add_argument("--start", type=int, default=1, help="first line to print")
    file_parser.add_argument("--limit", type=int, default=100, help="maximum lines to print; 0 means all")

    log = subparsers.add_parser("log", help="show raw source git history for a path")
    log.add_argument("path", help="path relative to raw/postgres-NN/")
    log.add_argument("--limit", type=int, default=20, help="maximum commits to print")

    includes = subparsers.add_parser("includes", help="show direct raw #include directives for a source file")
    includes.add_argument("path", help="path relative to raw/postgres-NN/")
    includes.add_argument("--format", choices=("text", "json"), default="text", help="output format")

    included_by = subparsers.add_parser("included-by", help="scan raw source for files including a header")
    included_by.add_argument("target", help="include target such as executor/executor.h or a raw-relative path")
    included_by.add_argument("--limit", type=int, default=100, help="maximum rows to print; 0 means all")
    included_by.add_argument("--format", choices=("text", "json"), default="text", help="output format")

    query = subparsers.add_parser("query", help="run graphify query against graph.json")
    query.add_argument("question", help="natural-language graph query")
    query.add_argument("--dfs", action="store_true", help="pass --dfs to Graphify")
    query.add_argument("--budget", type=int, help="pass --budget to Graphify")

    path = subparsers.add_parser("path", help="find an exact graph path between two nodes")
    path.add_argument("source", help="source node")
    path.add_argument("target", help="target node")

    explain = subparsers.add_parser("explain", help="explain one graph node")
    explain.add_argument("node", help="node name")

    args = parser.parse_args(argv)
    append_tool_log("source_graph_query", sys.argv[1:])

    versions = load_versions()
    if args.version not in versions:
        die(f"unsupported PostgreSQL version: {args.version}")

    root = source_checkout(args.version)
    if args.command == "symbol":
        return search_symbol(root, args.symbol, args.limit, args.regex)
    if args.command == "file":
        return print_file(safe_source_path(args.version, args.path), max(args.start, 1), args.limit)
    if args.command == "log":
        safe_source_path(args.version, args.path)
        return show_log(root, args.path, args.limit)
    if args.command == "includes":
        return show_includes(args.version, args.path, as_json=args.format == "json")
    if args.command == "included-by":
        return show_included_by(args.version, args.target, limit=args.limit, as_json=args.format == "json")

    command = ["graphify", args.command]
    if args.command == "query":
        command.append(args.question)
        if args.dfs:
            command.append("--dfs")
        if args.budget is not None:
            command.extend(["--budget", str(args.budget)])
    elif args.command == "path":
        command.extend([args.source, args.target])
    elif args.command == "explain":
        command.append(args.node)
    command.extend(["--graph", str(ensure_graph(args.version))])
    return run_graphify(command)


if __name__ == "__main__":
    raise SystemExit(main())
