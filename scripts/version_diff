#!/usr/bin/env python3
"""Diff a file across two project-local PostgreSQL source checkouts."""

from __future__ import annotations

import argparse
import difflib
import re
import sys
from pathlib import Path

sys.dont_write_bytecode = True

from wiki_tooling import RUNTIME_ROOT, append_tool_log, safe_source_path


def safe_diff_name(from_version: str, to_version: str, rel_path: str) -> str:
    cleaned = re.sub(r"[^A-Za-z0-9._-]+", "_", rel_path.strip("/"))
    return f"postgres-{from_version}_to_postgres-{to_version}_{cleaned}.diff"


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--from", dest="from_version", required=True, help="source PostgreSQL major version")
    parser.add_argument("--to", dest="to_version", required=True, help="target PostgreSQL major version")
    parser.add_argument("--path", required=True, help="source path to compare, relative to both checkouts")
    parser.add_argument("--context", type=int, default=3, help="unified diff context lines")
    args = parser.parse_args(argv)

    append_tool_log("version_diff", sys.argv[1:])

    from_path = safe_source_path(args.from_version, args.path)
    to_path = safe_source_path(args.to_version, args.path)
    if not from_path.exists():
        print(f"error: source file does not exist: {from_path}", file=sys.stderr)
        return 2
    if not to_path.exists():
        print(f"error: target file does not exist: {to_path}", file=sys.stderr)
        return 2

    from_lines = from_path.read_text(encoding="utf-8", errors="replace").splitlines(keepends=True)
    to_lines = to_path.read_text(encoding="utf-8", errors="replace").splitlines(keepends=True)
    diff = list(
        difflib.unified_diff(
            from_lines,
            to_lines,
            fromfile=f"postgres-{args.from_version}/{args.path}",
            tofile=f"postgres-{args.to_version}/{args.path}",
            n=args.context,
        )
    )

    output_dir = RUNTIME_ROOT / "tmp" / "version_diff"
    output_dir.mkdir(parents=True, exist_ok=True)
    output_path = output_dir / safe_diff_name(args.from_version, args.to_version, args.path)
    output_path.write_text("".join(diff), encoding="utf-8")

    if diff:
        print("".join(diff), end="")
        print(f"\nwritten: {output_path}")
        return 1

    print(f"no differences for {args.path}")
    print(f"written: {output_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
