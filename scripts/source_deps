#!/usr/bin/env python3
"""Query dependency context from a generated PostgreSQL source-context pack.

The output is orientation material for agents.  Behavioral claims still need
citations into the matching raw/postgres-NN/ checkout.

Examples:
  scripts/source_deps --version 12 --includes src/backend/storage/buffer/bufmgr.c
  scripts/source_deps --version 12 --included-by storage/bufmgr.h --limit 20
  scripts/source_deps --version 12 --compile-unit src/backend/storage/buffer/bufmgr.c
  scripts/source_deps --version 12 --transitive-includes src/backend/storage/buffer/bufmgr.c --depth 2
"""

from __future__ import annotations

import argparse
import json
import re
import shlex
import sys
from collections import Counter, deque
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable

sys.dont_write_bytecode = True

from wiki_tooling import REPO_ROOT, RUNTIME_ROOT, append_tool_log, die, load_versions, primary_version, source_checkout


INCLUDE_RE = re.compile(r"^\s*#\s*include\s+[<\"]([^>\"]+)[>\"]")
INCLUDE_DIR_RE = re.compile(r"^-\s+`(.+)`\s*$")


@dataclass(frozen=True)
class IncludeEdge:
    source: str
    include: str


@dataclass
class Context:
    version: str
    source: Path
    context_dir: Path
    include_dirs: list[Path]
    edges_by_source: dict[str, list[str]]
    compile_entries_by_file: dict[str, list[dict[str, object]]]


def render_path(path: Path | str) -> str:
    raw = Path(path) if not isinstance(path, Path) else path
    try:
        return raw.resolve().relative_to(REPO_ROOT).as_posix()
    except (OSError, ValueError):
        return str(path)


def path_from_context(text: str) -> Path:
    path = Path(text)
    if path.is_absolute():
        return path.resolve()
    return (REPO_ROOT / path).resolve()


def unique_paths(paths: Iterable[Path]) -> list[Path]:
    seen: set[str] = set()
    result: list[Path] = []
    for path in paths:
        key = str(path.resolve())
        if key in seen:
            continue
        seen.add(key)
        result.append(path.resolve())
    return result


def parse_include_dirs(args: list[str]) -> list[str]:
    include_dirs: list[str] = []
    index = 0
    joined_flags = {"-I", "-iquote", "-isystem", "-idirafter"}
    while index < len(args):
        arg = args[index]
        if arg in joined_flags and index + 1 < len(args):
            include_dirs.append(args[index + 1])
            index += 2
            continue
        if arg.startswith("-I") and len(arg) > 2:
            include_dirs.append(arg[2:])
        index += 1
    return include_dirs


def textual_include_edges(path: Path) -> list[str]:
    includes: list[str] = []
    try:
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
            match = INCLUDE_RE.match(line)
            if match:
                includes.append(match.group(1))
    except OSError:
        return []
    return includes


def entry_directory(entry: dict[str, object]) -> Path:
    raw = entry.get("directory")
    if isinstance(raw, str) and raw:
        path = Path(raw)
        if path.is_absolute():
            return path.resolve()
        return (REPO_ROOT / path).resolve()
    return REPO_ROOT


def entry_file(entry: dict[str, object]) -> Path | None:
    raw = entry.get("file")
    if not isinstance(raw, str) or not raw:
        return None
    path = Path(raw)
    if path.is_absolute():
        return path.resolve()
    return (entry_directory(entry) / path).resolve()


def entry_args(entry: dict[str, object]) -> list[str]:
    args = entry.get("arguments")
    if isinstance(args, list):
        return [str(arg) for arg in args]
    command = entry.get("command")
    if isinstance(command, str):
        return shlex.split(command)
    return []


def entry_include_dirs(entry: dict[str, object]) -> list[Path]:
    directory = entry_directory(entry)
    paths: list[Path] = []
    for include_dir in parse_include_dirs(entry_args(entry)):
        path = Path(include_dir)
        if path.is_absolute():
            paths.append(path.resolve())
        else:
            paths.append((directory / path).resolve())
    return unique_paths(paths)


def entry_defines(entry: dict[str, object]) -> list[str]:
    args = entry_args(entry)
    defines: list[str] = []
    index = 0
    while index < len(args):
        arg = args[index]
        if arg == "-D" and index + 1 < len(args):
            defines.append(args[index + 1])
            index += 2
            continue
        if arg.startswith("-D") and len(arg) > 2:
            defines.append(arg[2:])
        index += 1
    return defines


def load_include_context(version: str, context_dir: Path) -> tuple[list[Path], dict[str, list[str]]]:
    path = context_dir / "include-deps.txt"
    if not path.is_file():
        die(f"missing include context: {render_path(path)}; run scripts/source_context --version {version}")

    include_dirs: list[Path] = []
    edges_by_source: dict[str, list[str]] = {}
    section = ""
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        stripped = line.strip()
        if stripped == "## Build Include Directories":
            section = "include_dirs"
            continue
        if stripped == "## Direct Include Edges":
            section = "edges"
            continue
        if stripped.startswith("## "):
            section = ""
            continue

        if section == "include_dirs":
            match = INCLUDE_DIR_RE.match(stripped)
            if match:
                include_dirs.append(path_from_context(match.group(1)))
            continue

        if section == "edges" and stripped and not stripped.startswith("#"):
            try:
                source, include = stripped.split(": ", 1)
            except ValueError:
                continue
            source_path = path_from_context(source)
            source_label = render_path(source_path)
            edges_by_source.setdefault(source_label, []).append(include)

    if not edges_by_source:
        die(f"unsupported or empty include-deps format in {render_path(path)}")
    return unique_paths(include_dirs), edges_by_source


def load_compile_entries(version: str, context_dir: Path) -> dict[str, list[dict[str, object]]]:
    path = context_dir / "compile_commands.json"
    if not path.is_file():
        die(f"missing compiler database: {render_path(path)}; run scripts/source_context --version {version}")
    try:
        entries = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        die(f"could not parse {render_path(path)}: {exc}")
    if not isinstance(entries, list):
        die(f"compiler database is not a JSON array: {render_path(path)}")

    by_file: dict[str, list[dict[str, object]]] = {}
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        file_path = entry_file(entry)
        if file_path is None:
            continue
        by_file.setdefault(render_path(file_path), []).append(entry)
    return by_file


def load_context(version: str) -> Context:
    source = source_checkout(version).resolve()
    context_dir = RUNTIME_ROOT / "context" / f"postgres-{version}"
    manifest = context_dir / "manifest.md"
    if not manifest.is_file():
        die(f"missing context manifest: {render_path(manifest)}; run scripts/source_context --version {version}")
    include_dirs, edges_by_source = load_include_context(version, context_dir)
    compile_entries = load_compile_entries(version, context_dir)
    return Context(
        version=version,
        source=source,
        context_dir=context_dir,
        include_dirs=include_dirs,
        edges_by_source=edges_by_source,
        compile_entries_by_file=compile_entries,
    )


def allowed_project_file(ctx: Context, path: Path) -> bool:
    try:
        rel = path.resolve().relative_to(REPO_ROOT).as_posix()
    except ValueError:
        return False
    return rel.startswith(f"raw/postgres-{ctx.version}/") or rel.startswith(f".wiki-runtime/build/postgres-{ctx.version}/")


def maybe_resolve_input_file(ctx: Context, value: str) -> Path | None:
    candidates: list[Path] = []
    raw_path = Path(value)
    if raw_path.is_absolute():
        candidates.append(raw_path)
    else:
        candidates.append(REPO_ROOT / raw_path)
        candidates.append(ctx.source / raw_path)
        for include_dir in ctx.include_dirs:
            candidates.append(include_dir / raw_path)

    for candidate in candidates:
        resolved = candidate.resolve()
        if resolved.is_file() and allowed_project_file(ctx, resolved):
            return resolved
    return None


def resolve_input_file(ctx: Context, value: str) -> Path:
    resolved = maybe_resolve_input_file(ctx, value)
    if resolved is not None:
        return resolved
    die(
        f"could not resolve {value!r} inside raw/postgres-{ctx.version}/ "
        f"or .wiki-runtime/build/postgres-{ctx.version}/"
    )


def search_dirs_for_file(ctx: Context, source_label: str) -> list[Path]:
    entries = ctx.compile_entries_by_file.get(source_label)
    if entries:
        return entry_include_dirs(entries[0])
    return ctx.include_dirs


def direct_includes(ctx: Context, source_label: str) -> tuple[list[str], str]:
    includes = ctx.edges_by_source.get(source_label)
    if includes is not None:
        return includes, "include-deps.txt"

    path = (REPO_ROOT / source_label).resolve()
    if path.is_file() and allowed_project_file(ctx, path):
        return textual_include_edges(path), "source scan"
    return [], "not found"


def classify_resolved(ctx: Context, path: Path | None) -> str:
    if path is None:
        return "unresolved"
    rel = render_path(path)
    if rel.startswith(f"raw/postgres-{ctx.version}/"):
        return "raw"
    if rel.startswith(f".wiki-runtime/build/postgres-{ctx.version}/"):
        return "build"
    return "project"


def resolve_include(ctx: Context, source_label: str, include: str, search_dirs: list[Path]) -> tuple[str | None, str]:
    source_path = (REPO_ROOT / source_label).resolve()
    candidates = [source_path.parent / include]
    candidates.extend(include_dir / include for include_dir in search_dirs)

    for candidate in candidates:
        resolved = candidate.resolve()
        if resolved.is_file() and allowed_project_file(ctx, resolved):
            return render_path(resolved), classify_resolved(ctx, resolved)
    return None, "unresolved"


def edge_rows(ctx: Context, source_label: str, includes: list[str], search_dirs: list[Path]) -> list[dict[str, object]]:
    rows: list[dict[str, object]] = []
    for include in includes:
        resolved, kind = resolve_include(ctx, source_label, include, search_dirs)
        rows.append(
            {
                "source": source_label,
                "include": include,
                "resolved": resolved,
                "kind": kind,
            }
        )
    return rows


def print_direct(ctx: Context, source_label: str, rows: list[dict[str, object]], origin: str, limit: int) -> int:
    print(f"# Direct Includes (PostgreSQL {ctx.version})")
    print(f"source: {source_label}")
    print(f"edge_source: {origin}")
    if limit > 0 and len(rows) > limit:
        shown = rows[:limit]
        truncated = len(rows) - limit
    else:
        shown = rows
        truncated = 0
    for row in shown:
        suffix = f" -> {row['resolved']} [{row['kind']}]" if row["resolved"] else " -> unresolved"
        print(f"- {row['include']}{suffix}")
    if truncated:
        print(f"... truncated {truncated} include(s); raise --limit to see more")
    return 0 if rows else 1


def include_text_candidates(ctx: Context, value: str, resolved_path: Path | None) -> set[str]:
    candidates = {value}
    path_text = value.replace("\\", "/")
    if "/" in path_text:
        candidates.add(path_text.strip("/"))
    else:
        candidates.add(Path(value).name)

    path = resolved_path
    if path is not None:
        try:
            rel_source = path.resolve().relative_to(ctx.source).as_posix()
            candidates.add(rel_source)
            if rel_source.startswith("src/include/"):
                candidates.add(rel_source.removeprefix("src/include/"))
            if rel_source.startswith("src/backend/"):
                candidates.add(rel_source.removeprefix("src/backend/"))
        except ValueError:
            pass
        try:
            rel_build = path.resolve().relative_to((RUNTIME_ROOT / "build" / f"postgres-{ctx.version}").resolve())
            rel_build_text = rel_build.as_posix()
            candidates.add(rel_build_text)
            if rel_build_text.startswith("src/include/"):
                candidates.add(rel_build_text.removeprefix("src/include/"))
        except ValueError:
            pass
    return {candidate for candidate in candidates if candidate}


def edge_matches_target(
    ctx: Context,
    edge: IncludeEdge,
    target_texts: set[str],
    target_path: Path | None,
    query: str,
) -> bool:
    include = edge.include
    if include in target_texts:
        return True

    query_has_slash = "/" in query or "\\" in query
    if query_has_slash and any(text.endswith("/" + include) for text in target_texts):
        return True
    if not query_has_slash and Path(include).name == query:
        return True

    if target_path is None or Path(include).name != target_path.name:
        return False
    search_dirs = search_dirs_for_file(ctx, edge.source)
    resolved, _ = resolve_include(ctx, edge.source, include, search_dirs)
    return resolved == render_path(target_path)


def print_included_by(ctx: Context, query: str, limit: int) -> int:
    target_path = maybe_resolve_input_file(ctx, query)
    target_texts = include_text_candidates(ctx, query, target_path)

    matches: list[IncludeEdge] = []
    for source, includes in ctx.edges_by_source.items():
        for include in includes:
            edge = IncludeEdge(source=source, include=include)
            if edge_matches_target(ctx, edge, target_texts, target_path, query):
                matches.append(edge)

    counts = Counter(edge.source for edge in matches)
    sources = sorted(counts)
    if limit > 0:
        shown = sources[:limit]
        truncated = len(sources) - len(shown)
    else:
        shown = sources
        truncated = 0

    print(f"# Included By (PostgreSQL {ctx.version})")
    print(f"target: {query}")
    if target_path is not None:
        print(f"resolved_target: {render_path(target_path)}")
    print(f"matched_sources: {len(sources)}")
    for source in shown:
        duplicate = f" ({counts[source]} include directives)" if counts[source] > 1 else ""
        print(f"- {source}{duplicate}")
    if truncated > 0:
        print(f"... truncated {truncated} source file(s); raise --limit to see more")
    return 0 if matches else 1


def print_compile_unit(ctx: Context, source_label: str, entries: list[dict[str, object]], full_command: bool) -> int:
    if not entries:
        print(f"no compile_commands.json entry for {source_label}", file=sys.stderr)
        return 1

    entry = entries[0]
    args = entry_args(entry)
    output = entry.get("output")
    print(f"# Compile Unit (PostgreSQL {ctx.version})")
    print(f"file: {source_label}")
    print(f"directory: {render_path(entry_directory(entry))}")
    if isinstance(output, str) and output:
        print(f"output: {output}")
    if args:
        print(f"compiler: {args[0]}")
    if len(entries) > 1:
        print(f"matching_entries: {len(entries)}")

    defines = entry_defines(entry)
    print("")
    print("## Defines")
    if defines:
        for define in defines:
            print(f"- {define}")
    else:
        print("- none")

    print("")
    print("## Include Directories")
    include_dirs = entry_include_dirs(entry)
    if include_dirs:
        for include_dir in include_dirs:
            print(f"- {render_path(include_dir)}")
    else:
        print("- none")

    if full_command and args:
        print("")
        print("## Command")
        print(shlex.join(args))
    return 0


def transitive_rows(ctx: Context, root_label: str, depth: int, limit: int) -> tuple[list[dict[str, object]], bool]:
    rows: list[dict[str, object]] = []
    root_dirs = search_dirs_for_file(ctx, root_label)
    queue: deque[tuple[str, int, list[Path]]] = deque([(root_label, 0, root_dirs)])
    expanded: set[str] = set()
    truncated = False

    while queue:
        source_label, level, search_dirs = queue.popleft()
        if source_label in expanded:
            continue
        expanded.add(source_label)
        includes, origin = direct_includes(ctx, source_label)
        for row in edge_rows(ctx, source_label, includes, search_dirs):
            row["depth"] = level + 1
            row["edge_source"] = origin
            rows.append(row)
            if limit > 0 and len(rows) >= limit:
                truncated = True
                return rows, truncated
            resolved = row.get("resolved")
            if isinstance(resolved, str) and level + 1 < depth and resolved not in expanded:
                queue.append((resolved, level + 1, search_dirs))
    return rows, truncated


def print_transitive(ctx: Context, root_label: str, rows: list[dict[str, object]], depth: int, truncated: bool) -> int:
    print(f"# Transitive Includes (PostgreSQL {ctx.version})")
    print(f"root: {root_label}")
    print(f"max_depth: {depth}")
    for row in rows:
        suffix = f" -> {row['resolved']} [{row['kind']}]" if row["resolved"] else " -> unresolved"
        print(f"[{row['depth']}] {row['source']}: {row['include']}{suffix}")
    if truncated:
        print("... truncated by --limit")
    return 0 if rows else 1


def json_output(payload: object) -> int:
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


def selected_source_label(ctx: Context, value: str) -> str:
    return render_path(resolve_input_file(ctx, value))


def main(argv: list[str] | None = None) -> int:
    versions = load_versions()
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--version", default=primary_version(versions), help="PostgreSQL major version, defaults to primary")
    action = parser.add_mutually_exclusive_group(required=True)
    action.add_argument("--includes", metavar="PATH", help="show direct includes for a source or header path")
    action.add_argument("--included-by", metavar="HEADER", help="show files that directly include a header text/path")
    action.add_argument("--compile-unit", metavar="PATH", help="show compile_commands.json context for a source file")
    action.add_argument("--transitive-includes", metavar="PATH", help="show bounded transitive include edges")
    parser.add_argument("--depth", type=int, default=2, help="maximum depth for --transitive-includes")
    parser.add_argument("--limit", type=int, default=100, help="maximum rows to print; 0 means unlimited")
    parser.add_argument("--format", choices=("text", "json"), default="text", help="output format")
    parser.add_argument("--full-command", action="store_true", help="include the full compiler command for --compile-unit")
    args = parser.parse_args(argv)

    append_tool_log("source_deps", sys.argv[1:])
    if args.version not in versions:
        die(f"unsupported PostgreSQL version: {args.version}")

    ctx = load_context(args.version)

    if args.includes:
        source_label = selected_source_label(ctx, args.includes)
        includes, origin = direct_includes(ctx, source_label)
        rows = edge_rows(ctx, source_label, includes, search_dirs_for_file(ctx, source_label))
        if args.format == "json":
            return json_output({"version": ctx.version, "source": source_label, "edge_source": origin, "includes": rows})
        return print_direct(ctx, source_label, rows, origin, args.limit)

    if args.included_by:
        if args.format == "json":
            target_path = maybe_resolve_input_file(ctx, args.included_by)
            target_texts = include_text_candidates(ctx, args.included_by, target_path)
            matches = [
                edge
                for source, includes in ctx.edges_by_source.items()
                for edge in (IncludeEdge(source=source, include=include) for include in includes)
                if edge_matches_target(ctx, edge, target_texts, target_path, args.included_by)
            ]
            counts = Counter(edge.source for edge in matches)
            sources = sorted(counts)
            if args.limit > 0:
                sources = sources[: args.limit]
            return json_output(
                {
                    "version": ctx.version,
                    "target": args.included_by,
                    "resolved_target": render_path(target_path) if target_path is not None else None,
                    "sources": [{"source": source, "include_directives": counts[source]} for source in sources],
                }
            )
        return print_included_by(ctx, args.included_by, args.limit)

    if args.compile_unit:
        source_label = selected_source_label(ctx, args.compile_unit)
        entries = ctx.compile_entries_by_file.get(source_label, [])
        if args.format == "json":
            return json_output({"version": ctx.version, "source": source_label, "compile_entries": entries})
        return print_compile_unit(ctx, source_label, entries, args.full_command)

    if args.transitive_includes:
        root_label = selected_source_label(ctx, args.transitive_includes)
        depth = max(args.depth, 1)
        rows, truncated = transitive_rows(ctx, root_label, depth, args.limit)
        if args.format == "json":
            return json_output(
                {
                    "version": ctx.version,
                    "root": root_label,
                    "max_depth": depth,
                    "truncated": truncated,
                    "includes": rows,
                }
            )
        return print_transitive(ctx, root_label, rows, depth, truncated)

    return 2


if __name__ == "__main__":
    raise SystemExit(main())
