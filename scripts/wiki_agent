#!/usr/bin/env python3
"""Start, stop, and inspect the project-local wiki maintainer agent."""

from __future__ import annotations

import argparse
import json
import os
import shlex
import signal
import subprocess
import sys
import time
from pathlib import Path

sys.dont_write_bytecode = True

from wiki_tooling import REPO_ROOT, RUNTIME_ROOT, append_tool_log, die, ensure_runtime_dirs


AGENT_ROOT = RUNTIME_ROOT / "hermes"
PID_FILE = AGENT_ROOT / "wiki-agent.pid"
COMMAND_FILE = AGENT_ROOT / "wiki-agent.command"
ENV_FILE = AGENT_ROOT / "wiki-agent.env"
STDOUT_LOG = AGENT_ROOT / "wiki-agent.stdout.log"
STDERR_LOG = AGENT_ROOT / "wiki-agent.stderr.log"
EVENT_LOG = AGENT_ROOT / "wiki-agent.events.log"

LOG_ROTATE_BYTES = 50 * 1024 * 1024

ENV_ALLOWLIST = frozenset({
    "WIKI_AGENT_COMMAND",
    "WIKI_AGENT_WORKDIR",
    "WIKI_RUNTIME",
    "HERMES_HOME",
    "HF_HOME",
    "HF_TOKEN",
    "TRANSFORMERS_CACHE",
    "OLLAMA_HOST",
    "OLLAMA_MODELS",
    "XDG_CACHE_HOME",
    "TMPDIR",
    "CUDA_VISIBLE_DEVICES",
})


def ensure_agent_dirs() -> None:
    ensure_runtime_dirs()
    for path in (
        AGENT_ROOT,
        RUNTIME_ROOT / "huggingface",
        RUNTIME_ROOT / "ollama" / "models",
        RUNTIME_ROOT / "models",
        RUNTIME_ROOT / "cache",
        RUNTIME_ROOT / "tmp",
        RUNTIME_ROOT / "logs",
    ):
        path.mkdir(parents=True, exist_ok=True)


def log_event(message: str) -> None:
    ensure_agent_dirs()
    timestamp = time.strftime("%Y-%m-%dT%H:%M:%S")
    with EVENT_LOG.open("a", encoding="utf-8") as handle:
        handle.write(f"{timestamp} {message}\n")


def check_env_permissions() -> None:
    """Refuse to read wiki-agent.env when it is group- or world-writable.

    The env file controls the command we exec and selected env vars passed to
    the Hermes process. A writable file is an arbitrary-code-execution surface.
    """
    if not ENV_FILE.exists():
        return
    try:
        mode = ENV_FILE.stat().st_mode
    except OSError:
        return
    if mode & 0o022:
        die(
            f"refusing to read {ENV_FILE.relative_to(REPO_ROOT)}: file is "
            "group- or world-writable; run `chmod 600` on it and retry"
        )


def load_env_file() -> dict[str, str]:
    values: dict[str, str] = {}
    if not ENV_FILE.exists():
        return values

    check_env_permissions()
    for raw_line in ENV_FILE.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        if key not in ENV_ALLOWLIST:
            print(
                f"warning: ignoring {key} from {ENV_FILE.relative_to(REPO_ROOT)} "
                "(not in env allowlist)",
                file=sys.stderr,
            )
            continue
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
            value = value[1:-1]
        values[key] = value
    return values


def build_env() -> dict[str, str]:
    ensure_agent_dirs()
    env = os.environ.copy()
    for key, value in load_env_file().items():
        env.setdefault(key, value)

    env["WIKI_RUNTIME"] = str(RUNTIME_ROOT)
    env.setdefault("HERMES_HOME", str(AGENT_ROOT))
    env.setdefault("HF_HOME", str(RUNTIME_ROOT / "huggingface"))
    env.setdefault("TRANSFORMERS_CACHE", str(RUNTIME_ROOT / "huggingface"))
    env.setdefault("OLLAMA_MODELS", str(RUNTIME_ROOT / "ollama" / "models"))
    env.setdefault("XDG_CACHE_HOME", str(RUNTIME_ROOT / "cache"))
    env.setdefault("TMPDIR", str(RUNTIME_ROOT / "tmp"))
    env.setdefault("WIKI_AGENT_WORKDIR", str(REPO_ROOT))
    return env


def read_proc_starttime(pid: int) -> int | None:
    """Return the kernel-recorded start time (jiffies since boot) for `pid`.

    Used to detect PID reuse: if the live starttime does not match the value
    recorded when the agent was started, the PID belongs to a different process.
    """
    try:
        stat_text = Path(f"/proc/{pid}/stat").read_text(encoding="utf-8")
    except (FileNotFoundError, ProcessLookupError, PermissionError):
        return None
    rparen = stat_text.rfind(")")
    if rparen < 0:
        return None
    fields = stat_text[rparen + 1:].split()
    if len(fields) < 20:
        return None
    try:
        return int(fields[19])
    except ValueError:
        return None


def read_pid_record() -> tuple[int, int] | None:
    """Return (pid, starttime) from the pid file, or None if absent/invalid."""
    try:
        text = PID_FILE.read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        return None
    if not text:
        return None
    try:
        data = json.loads(text)
        return int(data["pid"]), int(data["starttime"])
    except (json.JSONDecodeError, KeyError, TypeError, ValueError):
        return None


def write_pid_record(pid: int, starttime: int) -> None:
    payload = json.dumps({"pid": pid, "starttime": starttime})
    PID_FILE.write_text(payload + "\n", encoding="utf-8")


def is_running(record: tuple[int, int] | None) -> bool:
    if not record:
        return False
    pid, recorded_starttime = record
    if pid <= 0:
        return False
    live_starttime = read_proc_starttime(pid)
    if live_starttime is None:
        return False
    return live_starttime == recorded_starttime


def remove_pid_file() -> None:
    try:
        PID_FILE.unlink()
    except FileNotFoundError:
        pass


def rotate_log(path: Path, max_bytes: int = LOG_ROTATE_BYTES) -> None:
    try:
        size = path.stat().st_size
    except FileNotFoundError:
        return
    if size < max_bytes:
        return
    backup = path.with_suffix(path.suffix + ".1")
    try:
        if backup.exists():
            backup.unlink()
        path.rename(backup)
    except OSError as exc:
        print(f"warning: log rotation failed for {path}: {exc}", file=sys.stderr)


def render_command(command: list[str]) -> str:
    return " ".join(shlex.quote(part) for part in command)


def command_from_args(raw: list[str], env: dict[str, str]) -> list[str]:
    if raw and raw[0] == "--":
        raw = raw[1:]
    if raw:
        return raw

    configured = env.get("WIKI_AGENT_COMMAND", "").strip()
    if configured:
        return shlex.split(configured)

    print(
        "error: no agent command configured; pass one after -- or set WIKI_AGENT_COMMAND "
        f"in {ENV_FILE.relative_to(REPO_ROOT)}",
        file=sys.stderr,
    )
    return []


def start(args: argparse.Namespace) -> int:
    env = build_env()
    record = read_pid_record()
    if record and is_running(record):
        print(f"wiki agent already running with pid {record[0]}")
        return 0
    if PID_FILE.exists():
        remove_pid_file()

    command = command_from_args(args.command, env)
    if not command:
        return 2

    append_tool_log("wiki_agent", ["start", render_command(command)])
    rotate_log(STDOUT_LOG)
    rotate_log(STDERR_LOG)
    with STDOUT_LOG.open("a", encoding="utf-8") as stdout, STDERR_LOG.open("a", encoding="utf-8") as stderr:
        process = subprocess.Popen(
            command,
            cwd=REPO_ROOT,
            env=env,
            stdin=subprocess.DEVNULL,
            stdout=stdout,
            stderr=stderr,
            start_new_session=True,
        )

    COMMAND_FILE.write_text(f"{render_command(command)}\n", encoding="utf-8")
    log_event(f"started pid={process.pid} command={render_command(command)}")

    time.sleep(args.startup_grace)
    if process.poll() is not None:
        log_event(f"start failed pid={process.pid} exit={process.returncode}")
        print(f"wiki agent exited during startup with code {process.returncode}", file=sys.stderr)
        print(f"stderr: {STDERR_LOG.relative_to(REPO_ROOT)}", file=sys.stderr)
        return process.returncode or 1

    starttime = read_proc_starttime(process.pid)
    if starttime is None:
        print(
            f"error: started pid {process.pid} but could not read /proc to record its starttime; "
            "send SIGTERM manually and retry",
            file=sys.stderr,
        )
        return 1

    write_pid_record(process.pid, starttime)
    print(f"wiki agent started with pid {process.pid}")
    print(f"stdout: {STDOUT_LOG.relative_to(REPO_ROOT)}")
    print(f"stderr: {STDERR_LOG.relative_to(REPO_ROOT)}")
    return 0


def stop(args: argparse.Namespace) -> int:
    append_tool_log("wiki_agent", ["stop"])
    record = read_pid_record()
    if record is None:
        if PID_FILE.exists():
            print(
                f"refusing to stop: {PID_FILE.relative_to(REPO_ROOT)} is unparseable; "
                "verify no Hermes process is running and remove it manually",
                file=sys.stderr,
            )
            return 1
        print("wiki agent is not running")
        return 0
    pid, _ = record
    if not is_running(record):
        remove_pid_file()
        print(f"removed stale pid file for pid {pid}")
        return 0

    os.kill(pid, signal.SIGTERM)
    deadline = time.time() + args.timeout
    while time.time() < deadline:
        if not is_running(record):
            remove_pid_file()
            log_event(f"stopped pid={pid}")
            print(f"wiki agent stopped pid {pid}")
            return 0
        time.sleep(0.2)

    if args.force:
        os.kill(pid, signal.SIGKILL)
        remove_pid_file()
        log_event(f"force-stopped pid={pid}")
        print(f"wiki agent force-stopped pid {pid}")
        return 0

    print(f"wiki agent did not stop within {args.timeout:.1f}s; rerun with --force if needed", file=sys.stderr)
    return 1


def status(_: argparse.Namespace) -> int:
    append_tool_log("wiki_agent", ["status"])
    record = read_pid_record()
    if record is None and PID_FILE.exists():
        print(
            f"wiki agent pid file at {PID_FILE.relative_to(REPO_ROOT)} is unparseable",
            file=sys.stderr,
        )
        return 1
    if is_running(record):
        pid, _ = record  # type: ignore[misc]
        command = COMMAND_FILE.read_text(encoding="utf-8").strip() if COMMAND_FILE.exists() else "(unknown command)"
        print(f"wiki agent running pid {pid}")
        print(f"command: {command}")
        print(f"stdout: {STDOUT_LOG.relative_to(REPO_ROOT)}")
        print(f"stderr: {STDERR_LOG.relative_to(REPO_ROOT)}")
        return 0
    if record:
        pid, _ = record
        print(f"wiki agent stopped; stale pid file points to {pid}")
        return 1
    print("wiki agent stopped")
    return 1


def tail(path: Path, lines: int) -> str:
    if not path.exists():
        return ""
    content = path.read_text(encoding="utf-8", errors="replace").splitlines()
    return "\n".join(content[-lines:])


def logs(args: argparse.Namespace) -> int:
    append_tool_log("wiki_agent", ["logs", str(args.lines)])
    for label, path in (("events", EVENT_LOG), ("stdout", STDOUT_LOG), ("stderr", STDERR_LOG)):
        print(f"== {label}: {path.relative_to(REPO_ROOT)} ==")
        output = tail(path, args.lines)
        if output:
            print(output)
    return 0


def restart(args: argparse.Namespace) -> int:
    stop_args = argparse.Namespace(timeout=args.timeout, force=args.force)
    stop_code = stop(stop_args)
    if stop_code != 0:
        return stop_code
    return start(args)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="command_name", required=True)

    start_parser = subparsers.add_parser("start", help="start the maintainer agent")
    start_parser.add_argument("--startup-grace", type=float, default=0.5, help="seconds to wait for immediate startup failure")
    start_parser.add_argument("command", nargs=argparse.REMAINDER, help="agent command, usually after --")
    start_parser.set_defaults(func=start)

    stop_parser = subparsers.add_parser("stop", help="stop the maintainer agent")
    stop_parser.add_argument("--timeout", type=float, default=10.0, help="seconds to wait after SIGTERM")
    stop_parser.add_argument("--force", action="store_true", help="send SIGKILL if the agent does not stop")
    stop_parser.set_defaults(func=stop)

    status_parser = subparsers.add_parser("status", help="show whether the agent is running")
    status_parser.set_defaults(func=status)

    logs_parser = subparsers.add_parser("logs", help="show recent agent logs")
    logs_parser.add_argument("--lines", type=int, default=80, help="lines per log file")
    logs_parser.set_defaults(func=logs)

    restart_parser = subparsers.add_parser("restart", help="restart the maintainer agent")
    restart_parser.add_argument("--timeout", type=float, default=10.0, help="seconds to wait after SIGTERM")
    restart_parser.add_argument("--force", action="store_true", help="send SIGKILL if the agent does not stop")
    restart_parser.add_argument("--startup-grace", type=float, default=0.5, help="seconds to wait for immediate startup failure")
    restart_parser.add_argument("command", nargs=argparse.REMAINDER, help="agent command, usually after --")
    restart_parser.set_defaults(func=restart)

    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
