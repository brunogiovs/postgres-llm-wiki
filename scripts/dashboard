#!/usr/bin/env bash
# Start, stop, and inspect the project-local Hermes dashboard.
#
# Usage:
#   scripts/dashboard start
#   scripts/dashboard status
#   scripts/dashboard stop
#   scripts/dashboard restart
#
# Environment overrides:
#   HERMES_DASHBOARD_HOST=localhost
#   HERMES_DASHBOARD_PORT=9119
#   HERMES_DASHBOARD_TUI=0
#   HERMES_DASHBOARD_OPEN=1
#   HERMES_DASHBOARD_INSECURE=0

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

export WIKI_RUNTIME="${WIKI_RUNTIME:-$REPO_ROOT/.wiki-runtime}"
export HERMES_HOME="${HERMES_HOME:-$WIKI_RUNTIME/hermes}"
export HF_HOME="${HF_HOME:-$WIKI_RUNTIME/huggingface}"
export TRANSFORMERS_CACHE="${TRANSFORMERS_CACHE:-$WIKI_RUNTIME/huggingface}"
export OLLAMA_MODELS="${OLLAMA_MODELS:-$WIKI_RUNTIME/ollama/models}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$WIKI_RUNTIME/cache}"
export TMPDIR="${TMPDIR:-$WIKI_RUNTIME/tmp}"

mkdir -p "$HERMES_HOME" "$HF_HOME" "$OLLAMA_MODELS" "$XDG_CACHE_HOME" "$TMPDIR"

NODE_BIN="$WIKI_RUNTIME/env/node-prefix/bin"
if [ -d "$NODE_BIN" ]; then
  export PATH="$NODE_BIN:$PATH"
fi

HERMES_BIN="${HERMES_BIN:-$WIKI_RUNTIME/env/hermes-agent/bin/hermes}"
if [ ! -x "$HERMES_BIN" ]; then
  echo "dashboard: Hermes binary not found or not executable: $HERMES_BIN" >&2
  exit 2
fi

usage() {
  sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//'
}

dashboard_start() {
  local host="${HERMES_DASHBOARD_HOST:-localhost}"
  local port="${HERMES_DASHBOARD_PORT:-9119}"
  local open_flag=(--no-open)
  local tui_flag=(--tui)
  local insecure_flag=(--insecure)

  if [ "${HERMES_DASHBOARD_OPEN:-0}" = "1" ]; then
    open_flag=()
  fi
  if [ "${HERMES_DASHBOARD_TUI:-1}" = "0" ]; then
    tui_flag=()
  fi
  if [ "${HERMES_DASHBOARD_INSECURE:-1}" = "0" ]; then
    insecure_flag=()
  fi

  exec "$HERMES_BIN" dashboard \
    --host "$host" \
    --port "$port" \
    "${open_flag[@]}" \
    "${tui_flag[@]}" \
    "${insecure_flag[@]}" \
    "$@"
}

dashboard_status() {
  "$HERMES_BIN" dashboard --status "$@" || true
}

dashboard_stop() {
  "$HERMES_BIN" dashboard --stop "$@"
}

command="${1:-start}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$command" in
  start)
    dashboard_start "$@"
    ;;
  status)
    dashboard_status "$@"
    ;;
  stop)
    dashboard_stop "$@"
    ;;
  restart)
    "$HERMES_BIN" dashboard --stop || true
    dashboard_start "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "dashboard: unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
